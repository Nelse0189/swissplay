# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Firebase Admin SDK Configuration
# Download your service account key from Firebase Console
# Place it in this directory as 'serviceAccountKey.json'
FIREBASE_PROJECT_ID=solaris-cd166

# Optional: Server/Guild ID for faster slash command testing
# If set, commands will register to this guild only (appears immediately)
# If not set, commands register globally (may take up to 1 hour to appear)
# To get your guild ID: Enable Developer Mode in Discord, right-click server → Copy Server ID
DISCORD_GUILD_ID=your_server_id_here


